# Optional defaults for local Docker Compose usage.
# Server-side configuration only. Users do not enter credentials in the UI.
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_SKIP_RUNTIME_INSTALL=1
PORT=3000
WEB_PORT=3000

# Public site URL. Used for canonical links, sitemap, robots, JSON-LD and
# absolute URLs in metadata. Exposed to the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_SITE_URL=https://seofrendly.ru

# Public brand contact email. Rendered on /contacts, /privacy and in the
# Organization JSON-LD on the home page. Exposed to the browser (NEXT_PUBLIC_).
NEXT_PUBLIC_BRAND_EMAIL=hello@seofrendly.ru

# Yandex.Metrika counter ID. Leave empty to disable analytics injection.
# Public value, exposed via NEXT_PUBLIC_; must not contain secrets.
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Yandex.Metrika optional modules. Loaded from .env.production / .env.development
# (not committed, see .gitignore). Set to "true" to enable, anything else to disable.
# NEXT_PUBLIC_ENABLE_WEBVISOR=true
# NEXT_PUBLIC_ENABLE_CLICKMAP=true

# ---------------------------------------------------------------------------
# AI processing configuration (server-side only).
#
# IMPORTANT: NEVER prefix any of the variables below with NEXT_PUBLIC_.
# NEXT_PUBLIC_* values are embedded into the browser bundle and would expose
# the key to every visitor of the site. Keep all secrets in server-only env
# variables (no NEXT_PUBLIC_ prefix).
# ---------------------------------------------------------------------------

# Comma-separated list of private processing credentials. Each audit request
# picks one credential at random; the same credential is then used for the
# entire run with fallback applied as needed. Deduplicated and trimmed at
# startup.
# AI_API_KEYS=sk-key-1,sk-key-2,sk-key-3

# Alternatively (or additionally) you can supply numbered keys, which is
# useful when provisioning them through a secret manager. Any variable
# matching /^AI_API_KEY_\d+$/ is read, sorted numerically, and merged with
# AI_API_KEYS (duplicates removed).
# AI_API_KEY_1=sk-key-1
# AI_API_KEY_2=sk-key-2
# AI_API_KEY_3=sk-key-3

# Optional: place this preferred processing route first if it is available.
# If unset or unavailable, the discovered order is used as-is.
# AI_DEFAULT_ROUTE=
