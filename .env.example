# Optional defaults for local Docker Compose usage.
# API keys are entered in the UI and are not required here.
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
PLAYWRIGHT_BROWSERS_PATH=/ms-playwright
PLAYWRIGHT_SKIP_RUNTIME_INSTALL=1
PORT=3000
WEB_PORT=3000

# Yandex.Metrika counter ID. Leave empty to disable analytics injection.
# Public value, exposed via NEXT_PUBLIC_; must not contain secrets.
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Yandex.Metrika optional modules. Loaded from .env.production / .env.development
# (not committed, see .gitignore). Set to "true" to enable, anything else to disable.
# NEXT_PUBLIC_ENABLE_WEBVISOR=true
# NEXT_PUBLIC_ENABLE_CLICKMAP=true
